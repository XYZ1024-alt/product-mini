:host {
  padding-bottom: 100rpx;
}

.gap {
  height: 100rpx;
  width: 100%;
}

.t-button {
  --td-button-default-color: #000;
  --td-button-primary-text-color: #fa4126;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.cart-header__title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.cart-header__clear {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
}